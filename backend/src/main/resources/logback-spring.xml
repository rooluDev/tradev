<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 공통 프로퍼티 -->
    <property name="LOG_PATH" value="${LOG_PATH:-/app/logs}"/>
    <property name="APP_NAME" value="tradev"/>

    <!-- ===================== CONSOLE (로컬/개발용) ===================== -->
    <springProfile name="local">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) [%X{traceId:-}] - %msg%n</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.tradev" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>

        <!-- SQL 로깅 (로컬만) -->
        <logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- ===================== PROD / TEST — JSON 구조화 로그 ===================== -->
    <springProfile name="prod,test">

        <!-- JSON 콘솔 (Docker stdout → CloudWatch / ELK 수집용) -->
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <customFields>{"app":"${APP_NAME}","env":"${SPRING_PROFILES_ACTIVE:-prod}"}</customFields>
                <fieldNames>
                    <timestamp>time</timestamp>
                    <message>msg</message>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <levelValue>[ignore]</levelValue>
                </fieldNames>
                <timeZone>Asia/Seoul</timeZone>
                <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            </encoder>
        </appender>

        <!-- 파일 롤링 (JSON) -->
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${APP_NAME}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <customFields>{"app":"${APP_NAME}","env":"${SPRING_PROFILES_ACTIVE:-prod}"}</customFields>
                <timeZone>Asia/Seoul</timeZone>
                <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            </encoder>
        </appender>

        <!-- ERROR 전용 파일 -->
        <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${APP_NAME}-error.log</file>
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>ERROR</level>
            </filter>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${APP_NAME}-error-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <customFields>{"app":"${APP_NAME}","env":"${SPRING_PROFILES_ACTIVE:-prod}"}</customFields>
                <timeZone>Asia/Seoul</timeZone>
            </encoder>
        </appender>

        <root level="WARN">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>

        <logger name="com.tradev" level="INFO" additivity="false">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="JSON_FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>

        <!-- 느린 쿼리 경고 (P6Spy 없이 Hibernate 통계로 대체) -->
        <logger name="org.hibernate.orm.jdbc.bind" level="WARN" additivity="false">
            <appender-ref ref="JSON_FILE"/>
        </logger>

    </springProfile>

</configuration>
