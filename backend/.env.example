# Server
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tradev
DB_USERNAME=tradev
DB_PASSWORD=tradev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-must-be-at-least-32-bytes-long
JWT_ACCESS_EXPIRY=3600000
JWT_REFRESH_EXPIRY=604800000

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AWS / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=ap-northeast-2
AWS_ENDPOINT=http://localhost:9000
S3_BUCKET_NAME=tradev-local
S3_BASE_URL=http://localhost:9000/tradev-local

# Mail (Mailpit local)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@tradev.local

# Claude API
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
